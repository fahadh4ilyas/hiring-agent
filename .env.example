# LLM Provider Configuration
# Options: "ollama", "gemini", or "openai"
LLM_PROVIDER=ollama

# Default model to use
# For Ollama: "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Gemini: "gemini-2.5-pro", "gemini-2.5-flash", etc.
# For OpenAI / OpenAI-compatible: "gpt-4o", "gpt-4o-mini", "gpt-4.1", etc.
DEFAULT_MODEL=gemma3:4b

# Google Gemini API Key (required if using Gemini provider)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI / OpenAI-compatible API Key (required if using OpenAI provider)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI / OpenAI-compatible Base URL (optional — for custom endpoints)
# Leave empty for default OpenAI; set for Azure, local servers, etc.
# e.g. OPENAI_BASE_URL=https://api.openai.com/v1
